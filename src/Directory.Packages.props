<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup>
    <!-- Build infrastructure (referenced from Directory.Build.props) -->
    <PackageVersion Include="MinVer" Version="7.0.0" />
    <PackageVersion Include="CSharpier.MsBuild" Version="1.2.6" />

    <!-- Library dependencies -->
    <PackageVersion Include="FastEnum.Core" Version="2.0.6" />
    <PackageVersion Include="FastEnum.Generators" Version="2.0.6" />

    <!-- Analyzers -->
    <PackageVersion Include="Meziantou.Analyzer" Version="3.0.20" />

    <!-- Testing -->
    <PackageVersion Include="TUnit" Version="1.21.6" />
    <PackageVersion Include="PublicApiGenerator" Version="11.5.4" />

    <!-- Benchmarks -->
    <PackageVersion Include="BenchmarkDotNet" Version="0.15.8" />
    <PackageVersion Include="BenchmarkDotNet.Diagnostics.Windows" Version="0.15.8" />
  </ItemGroup>
</Project>
